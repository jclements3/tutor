<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.tutor.musictutor">

    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- USB-MIDI keyboard playthrough (MidiSynthService + native Oboe
         synth). Not required; the app still works without a MIDI device. -->
    <uses-feature android:name="android.software.midi" android:required="false" />
    <uses-feature android:name="android.hardware.usb.host" android:required="false" />

    <!-- Foreground service so the synth keeps running with the tutor
         UI closed. mediaPlayback type matches the audio-rendering work. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:usesCleartextTraffic="false"
        android:hardwareAccelerated="true"
        android:theme="@android:style/Theme.DeviceDefault.Light.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="unspecified"
            android:configChanges="orientation|screenSize|keyboardHidden">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- USB-MIDI auto-launcher: plug in any class-compliant USB MIDI
             device -> Android opens this transparent Activity, which fires
             the synth service and finishes immediately. -->
        <activity
            android:name=".UsbMidiAttachActivity"
            android:exported="true"
            android:theme="@android:style/Theme.NoDisplay"
            android:noHistory="true">
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/usb_midi_filter" />
        </activity>

        <service
            android:name=".MidiSynthService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />
    </application>
</manifest>
